		<Item class="Script" referent="7">
			<Properties>
				<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Teams = game:GetService("Teams")

local Constants = require(ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Constants"))

local LOBBY_FLOOR_SIZE = 40
local LOBBY_WALL_HEIGHT = 10
local ARENA_FLOOR_SIZE = 200
local SPAWN_PAD_SIZE = 6

local lobbyTeam = Instance.new("Team")
lobbyTeam.Name = "Lobby"
lobbyTeam.TeamColor = BrickColor.new("Bright blue")
lobbyTeam.AutoAssignable = true
lobbyTeam.Parent = Teams

local inGameTeam = Instance.new("Team")
inGameTeam.Name = "InGame"
inGameTeam.TeamColor = BrickColor.new("Bright red")
inGameTeam.AutoAssignable = false
inGameTeam.Parent = Teams

local function makePart(props: { [string]: any }): Part
	local part = Instance.new("Part")
	for key, value in props do
		(part :: any)[key] = value
	end
	return part
end

local lobbyFolder = Instance.new("Folder")
lobbyFolder.Name = "Lobby"
lobbyFolder.Parent = workspace

makePart({
	Name = "Floor",
	Size = Vector3.new(LOBBY_FLOOR_SIZE, 1, LOBBY_FLOOR_SIZE),
	Position = Constants.LobbyOrigin,
	Anchored = true,
	BrickColor = BrickColor.new("Light stone grey"),
	Parent = lobbyFolder,
})

local function makeWall(name: string, axis: string, sign: number)
	local size, position
	if axis == "z" then
		size = Vector3.new(LOBBY_FLOOR_SIZE, LOBBY_WALL_HEIGHT, 1)
		position = Constants.LobbyOrigin
			+ Vector3.new(0, LOBBY_WALL_HEIGHT / 2 + 0.5, sign * LOBBY_FLOOR_SIZE / 2)
	else
		size = Vector3.new(1, LOBBY_WALL_HEIGHT, LOBBY_FLOOR_SIZE)
		position = Constants.LobbyOrigin
			+ Vector3.new(sign * LOBBY_FLOOR_SIZE / 2, LOBBY_WALL_HEIGHT / 2 + 0.5, 0)
	end
	makePart({
		Name = name,
		Size = size,
		Position = position,
		Anchored = true,
		BrickColor = BrickColor.new("Medium stone grey"),
		Parent = lobbyFolder,
	})
end

makeWall("WallNorth", "z", -1)
makeWall("WallSouth", "z", 1)
makeWall("WallEast", "x", 1)
makeWall("WallWest", "x", -1)

local lobbySpawn = Instance.new("SpawnLocation")
lobbySpawn.Name = "LobbySpawn"
lobbySpawn.Size = Vector3.new(SPAWN_PAD_SIZE, 1, SPAWN_PAD_SIZE)
lobbySpawn.Position = Constants.LobbyOrigin + Vector3.new(0, 1, 0)
lobbySpawn.Anchored = true
lobbySpawn.TeamColor = lobbyTeam.TeamColor
lobbySpawn.Neutral = false
lobbySpawn.BrickColor = BrickColor.new("Bright blue")
lobbySpawn.Parent = lobbyFolder

local door = makePart({
	Name = "Door",
	Size = Vector3.new(6, 7, 1),
	Position = Constants.LobbyOrigin + Vector3.new(0, 4, LOBBY_FLOOR_SIZE / 2 - 1),
	Anchored = true,
	BrickColor = BrickColor.new("Reddish brown"),
	Material = Enum.Material.WoodPlanks,
	Parent = lobbyFolder,
})

local prompt = Instance.new("ProximityPrompt")
prompt.ActionText = "Enter Game"
prompt.ObjectText = "Door"
prompt.HoldDuration = 0
prompt.MaxActivationDistance = 8
prompt.Parent = door

local arenaFolder = Instance.new("Folder")
arenaFolder.Name = "Arena"
arenaFolder.Parent = workspace

makePart({
	Name = "Floor",
	Size = Vector3.new(ARENA_FLOOR_SIZE, 1, ARENA_FLOOR_SIZE),
	Position = Constants.ArenaOrigin,
	Anchored = true,
	BrickColor = BrickColor.new("Dirt brown"),
	Material = Enum.Material.Slate,
	Parent = arenaFolder,
})

local arenaSpawn = Instance.new("SpawnLocation")
arenaSpawn.Name = "ArenaSpawn"
arenaSpawn.Size = Vector3.new(SPAWN_PAD_SIZE, 1, SPAWN_PAD_SIZE)
arenaSpawn.Position = Constants.ArenaOrigin + Vector3.new(0, 1, 0)
arenaSpawn.Anchored = true
arenaSpawn.TeamColor = inGameTeam.TeamColor
arenaSpawn.Neutral = false
arenaSpawn.BrickColor = BrickColor.new("Bright red")
arenaSpawn.Parent = arenaFolder

prompt.Triggered:Connect(function(player)
	local character = player.Character
	if not character then
		return
	end
	local hrp = character:FindFirstChild("HumanoidRootPart") :: BasePart?
	if not hrp then
		return
	end

	player.Team = inGameTeam
	hrp.CFrame = arenaSpawn.CFrame + Vector3.new(0, 5, 0)
end)

local function onCharacter(player: Player, character: Model)
	local humanoid = character:WaitForChild("Humanoid") :: Humanoid
	humanoid.Died:Connect(function()
		player.Team = lobbyTeam
	end)
end

Players.PlayerAdded:Connect(function(player)
	player.CharacterAdded:Connect(function(character)
		onCharacter(player, character)
	end)
end)

for _, player in Players:GetPlayers() do
	player.CharacterAdded:Connect(function(character)
		onCharacter(player, character)
	end)
	if player.Character then
		onCharacter(player, player.Character)
	end
end

print("[GameLoop] world built, lobby + arena ready")
]]></ProtectedString>
