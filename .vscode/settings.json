{
  "files.associations": {
    "*.luau": "luau"
  },

  "[luau]": {
    "editor.defaultFormatter": "JohnnyMorganz.stylua",
    "editor.formatOnSave": true
  },

  "luau-lsp.sourcemap.enabled": true,
  "luau-lsp.sourcemap.autogenerate": true,
  "luau-lsp.sourcemap.rojoProjectFile": "default.project.json",
  "luau-lsp.sourcemap.includeNonScripts": true,
  "luau-lsp.types.roblox": true,
  "luau-lsp.types.robloxSecurityLevel": "PluginSecurity",

  "selene.run": "onSave",

  "stylua.searchParentDirectories": true,

  "search.exclude": {
    "build/": true,
    "**/Packages/": true,
    "sourcemap.json": true
  }
}
